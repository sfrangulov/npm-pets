{
  "name": "npm-pets",
  "version": "0.4.1",
  "description": "CLI for npm user and organization stats",
  "author": {
    "name": "Sergei Frangulov",
    "email": "sfrangulov@gmail.com",
    "url": "https://github.com/sfrangulov"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sfrangulov/npm-pets.git"
  },
  "homepage": "https://github.com/sfrangulov/npm-pets#readme",
  "bugs": {
    "url": "https://github.com/sfrangulov/npm-pets/issues"
  },
  "license": "MIT",
  "keywords": [
    "npm",
    "cli",
    "stats",
    "profile",
    "downloads",
    "github-stats"
  ],
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib.js",
      "types": "./dist/lib.d.ts"
    }
  },
  "bin": {
    "npm-pets": "./dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "citty": "^0.1.5",
    "cli-table3": "^0.6.5",
    "figlet": "^1.7.0",
    "satori": "^0.26.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
